OPENAI_API_KEY=
PORT=3203
HOST=127.0.0.1
VOX_MEMORY_DIR=.vox-memory
VOX_RECORDINGS_DIR=.vox-recordings
VOX_MAX_RECORDING_BYTES=52428800

# Production web auth. Set VOX_AUTH_REQUIRED=0 only for local development.
VOX_AUTH_REQUIRED=1
SUPABASE_URL=
SUPABASE_ANON_KEY=
VOX_ALLOWED_EMAILS=rick@exp.game
VOX_ALLOWED_DOMAINS=
# Dev-only: allows no-token loopback bridge calls when Host is localhost/127.0.0.1.
VOX_ALLOW_LOCAL_BRIDGE_BYPASS=0

# OpenAI Realtime defaults.
VOX_REALTIME_MODEL=gpt-realtime
VOX_REALTIME_VOICE=marin
VOX_TRANSCRIPTION_LANGUAGE=
